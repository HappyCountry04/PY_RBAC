# ═══════════════════════════════════════════════════════════════
#  RuoYi FastAPI 后端配置（示例文件，复制为 .env 后修改使用）
# ═══════════════════════════════════════════════════════════════

# ── 基础 ──────────────────────────────────────────────────────
APP_NAME=RuoYi FastAPI
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ruoyi_fastapi
REDIS_URL=redis://localhost:6379/0

# ── 安全 ──────────────────────────────────────────────────────
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=30
TOKEN_REFRESH_THRESHOLD_MINUTES=20
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── 验证码 ────────────────────────────────────────────────────
CAPTCHA_ENABLED=true
CAPTCHA_TYPE=math

# ── 密码策略 ──────────────────────────────────────────────────
PASSWORD_MAX_RETRY_COUNT=5
PASSWORD_LOCK_TIME_MINUTES=10

# ── 文件上传 ──────────────────────────────────────────────────
UPLOAD_PATH=uploads

# ── 防重复提交 ────────────────────────────────────────────────
REPEAT_SUBMIT_INTERVAL_MS=5000

# ── API 限流 ──────────────────────────────────────────────────
RATE_LIMIT_COUNT=100
RATE_LIMIT_TIME_SECONDS=60
